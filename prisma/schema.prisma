generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum IncomeFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
  CUSTOM
}

enum DebtStrategy {
  SNOWBALL
  AVALANCHE
  CUSTOM
}

enum AccountType {
  CHECKING
  DEBIT
  SAVINGS
  CASH
  INVESTMENT
  CREDIT_CARD
  LOAN
  OTHER
}

enum CardPaymentTracking {
  MINIMUM
  FULL_STATEMENT
  BOTH
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CategoryKind {
  INCOME
  EXPENSE
  SAVINGS
  DEBT
  TRANSFER
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
  CREDIT_CARD_PAYMENT
  LOAN_PAYMENT
  SAVINGS_CONTRIBUTION
  REFUND
  ADJUSTMENT
}

enum TransactionCadence {
  ONE_TIME
  RECURRING
  INSTALLMENT
}

enum TransactionPlanning {
  PLANNED
  UNPLANNED
}

enum RecurringFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  SEMIANNUALLY
  YEARLY
}

enum InstallmentStatus {
  ACTIVE
  COMPLETED
  PAID_OFF
  EARLY_SETTLED
  CANCELLED
}

enum BudgetScope {
  GLOBAL
  CATEGORY
  SUBCATEGORY
}

enum RuleType {
  THRESHOLD
  TREND
  ACCUMULATION
  CONCENTRATION
  RISK
  CUSTOM
}

enum InsightSeverity {
  INFO
  WARNING
  CRITICAL
  POSITIVE
}

enum InsightStatus {
  ACTIVE
  DISMISSED
  ARCHIVED
}

enum PlannedPurchaseStatus {
  IDEA
  RESEARCHING
  SAVING
  READY
  BOUGHT
  SKIPPED
}

enum RecommendationType {
  WAIT
  BUY_NOW
  SAVE_MORE
  CONSIDER_MSI
  AVOID
}

enum SeasonalityStrength {
  LOW
  MEDIUM
  HIGH
}

enum NotificationType {
  PAYMENT_DUE
  BUDGET_WARNING
  GOAL_RISK
  MSI_ALERT
  INSIGHT
  GENERIC
}

enum NotificationStatus {
  UNREAD
  READ
  ARCHIVED
}

model User {
  id                   String                 @id @default(cuid())
  email                String                 @unique
  passwordHash         String
  name                 String
  role                 Role                   @default(USER)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  settings             Settings?
  accounts             Account[]
  creditCards          CreditCard[]
  loans                Loan[]
  categories           Category[]
  subcategories        Subcategory[]
  tags                 Tag[]
  transactions         Transaction[]
  recurringExpenses    RecurringExpense[]
  installmentPurchases InstallmentPurchase[]
  savingsGoals         SavingsGoal[]
  budgets              Budget[]
  financialRules       FinancialRule[]
  spendingInsights     SpendingInsight[]
  plannedPurchases     PlannedPurchase[]
  purchaseSeasonality  PurchaseSeasonality[]
  notifications        Notification[]
}

model Settings {
  id                        String          @id @default(cuid())
  userId                    String          @unique
  currency                  String          @default("MXN")
  locale                    String          @default("es-MX")
  dateFormat                String          @default("dd/MM/yyyy")
  incomeFrequency           IncomeFrequency @default(BIWEEKLY)
  paydayDays                Int[]           @default([15, 30])
  debtStrategy              DebtStrategy    @default(AVALANCHE)
  defaultGoalPriority       Priority        @default(MEDIUM)
  cardStatementBufferDays   Int             @default(3)
  enableLocalInsights       Boolean         @default(true)
  weekStartsOn              Int             @default(1)
  projectedFlowMonths       Int             @default(12)
  categoryBudgetWarningPct  Int             @default(80)
  themeMode                 String          @default("light")
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt
  user                      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String        @id @default(cuid())
  userId                String
  name                  String
  type                  AccountType
  institution           String?
  last4                 String?
  currentBalance        Decimal       @db.Decimal(12, 2)
  availableBalance      Decimal?      @db.Decimal(12, 2)
  creditLimit           Decimal?      @db.Decimal(12, 2)
  color                 String?
  icon                  String?
  includeInNetWorth     Boolean       @default(true)
  isLiquid              Boolean       @default(true)
  isArchived            Boolean       @default(false)
  notes                 String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  creditCardProfile     CreditCard?
  loanProfile           Loan?
  outgoingTransactions  Transaction[] @relation("TransactionSourceAccount")
  incomingTransactions  Transaction[] @relation("TransactionDestinationAccount")
  recurringExpenses     RecurringExpense[]
  savingsGoals          SavingsGoal[]

  @@index([userId, type])
}

model CreditCard {
  id                     String              @id @default(cuid())
  userId                 String
  accountId              String              @unique
  name                   String
  bank                   String
  last4                  String
  statementClosingDay    Int
  paymentDueDay          Int
  creditLimit            Decimal             @db.Decimal(12, 2)
  annualInterestRate     Decimal?            @db.Decimal(5, 2)
  minimumPaymentRatio    Decimal?            @db.Decimal(5, 2)
  minimumDueAmount       Decimal?            @db.Decimal(12, 2)
  paymentTracking        CardPaymentTracking @default(BOTH)
  statementBalance       Decimal             @default(0) @db.Decimal(12, 2)
  payoffBalance          Decimal             @default(0) @db.Decimal(12, 2)
  nextStatementDate      DateTime?
  nextDueDate            DateTime?
  color                  String?
  icon                   String?
  notes                  String?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  user                   User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  account                Account             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  installmentPurchases   InstallmentPurchase[]

  @@index([userId, nextDueDate])
}

model Loan {
  id                 String    @id @default(cuid())
  userId             String
  accountId          String    @unique
  name               String
  lender             String?
  originalAmount     Decimal   @db.Decimal(12, 2)
  currentBalance     Decimal   @db.Decimal(12, 2)
  monthlyPayment     Decimal   @db.Decimal(12, 2)
  interestRate       Decimal?  @db.Decimal(5, 2)
  paymentDay         Int
  priority           Priority  @default(MEDIUM)
  strategyWeight     Int       @default(50)
  openedAt           DateTime  @default(now())
  targetPayoffDate   DateTime?
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  account            Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([userId, priority])
}

model Category {
  id                String             @id @default(cuid())
  userId            String
  name              String
  kind              CategoryKind
  icon              String?
  color             String?
  sortOrder         Int                @default(0)
  isSystem          Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  subcategories     Subcategory[]
  transactions      Transaction[]
  recurringExpenses RecurringExpense[]
  budgets           Budget[]
  installmentPurchases InstallmentPurchase[]
  spendingInsights  SpendingInsight[]

  @@unique([userId, name, kind])
}

model Subcategory {
  id                String             @id @default(cuid())
  userId            String
  categoryId        String
  name              String
  sortOrder         Int                @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  category          Category           @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  transactions      Transaction[]
  recurringExpenses RecurringExpense[]
  budgets           Budget[]

  @@unique([categoryId, name])
  @@index([userId, categoryId])
}

model Tag {
  id           String           @id @default(cuid())
  userId       String
  name         String
  color        String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions TransactionTag[]

  @@unique([userId, name])
}

model Transaction {
  id                     String               @id @default(cuid())
  userId                 String
  postedAt               DateTime
  amount                 Decimal              @db.Decimal(12, 2)
  currency               String               @default("MXN")
  type                   TransactionType
  cadence                TransactionCadence   @default(ONE_TIME)
  planning               TransactionPlanning  @default(UNPLANNED)
  description            String
  merchant               String?
  notes                  String?
  categoryId             String?
  subcategoryId          String?
  sourceAccountId        String?
  destinationAccountId   String?
  savingsGoalId          String?
  recurringExpenseId     String?
  installmentPurchaseId  String?
  metadata               Json?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  user                   User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  category               Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  subcategory            Subcategory?         @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  sourceAccount          Account?             @relation("TransactionSourceAccount", fields: [sourceAccountId], references: [id], onDelete: SetNull)
  destinationAccount     Account?             @relation("TransactionDestinationAccount", fields: [destinationAccountId], references: [id], onDelete: SetNull)
  savingsGoal            SavingsGoal?         @relation(fields: [savingsGoalId], references: [id], onDelete: SetNull)
  recurringExpense       RecurringExpense?    @relation(fields: [recurringExpenseId], references: [id], onDelete: SetNull)
  installmentPurchase    InstallmentPurchase? @relation(fields: [installmentPurchaseId], references: [id], onDelete: SetNull)
  tags                   TransactionTag[]

  @@index([userId, postedAt, type])
  @@index([categoryId, subcategoryId])
}

model TransactionTag {
  transactionId String
  tagId         String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  tag           Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([transactionId, tagId])
}

model RecurringExpense {
  id                String             @id @default(cuid())
  userId            String
  name              String
  amount            Decimal            @db.Decimal(12, 2)
  frequency         RecurringFrequency
  nextDueDate       DateTime
  reminderDays      Int                @default(3)
  isEssential       Boolean            @default(true)
  isActive          Boolean            @default(true)
  merchant          String?
  notes             String?
  categoryId        String
  subcategoryId     String?
  paymentAccountId  String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  category          Category           @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  subcategory       Subcategory?       @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  paymentAccount    Account?           @relation(fields: [paymentAccountId], references: [id], onDelete: SetNull)
  transactions      Transaction[]

  @@index([userId, nextDueDate, isActive])
}

model InstallmentPurchase {
  id                    String              @id @default(cuid())
  userId                String
  creditCardId          String
  categoryId            String?
  title                 String
  merchant              String?
  totalAmount           Decimal             @db.Decimal(12, 2)
  purchaseDate          DateTime
  totalMonths           Int
  monthlyAmount         Decimal             @db.Decimal(12, 2)
  firstChargeMonth      DateTime
  currentInstallment    Int                 @default(1)
  remainingBalance      Decimal             @db.Decimal(12, 2)
  status                InstallmentStatus   @default(ACTIVE)
  isManuallySettled     Boolean             @default(false)
  settledAt             DateTime?
  notes                 String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  user                  User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  creditCard            CreditCard          @relation(fields: [creditCardId], references: [id], onDelete: Cascade)
  category              Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  payments              InstallmentPayment[]
  transactions          Transaction[]
  spendingInsights      SpendingInsight[]

  @@index([userId, status, firstChargeMonth])
}

model InstallmentPayment {
  id                     String              @id @default(cuid())
  purchaseId             String
  installmentNumber      Int
  chargeMonth            DateTime
  dueDate                DateTime
  amount                 Decimal             @db.Decimal(12, 2)
  remainingAfterPayment  Decimal             @db.Decimal(12, 2)
  isPaid                 Boolean             @default(false)
  paidAt                 DateTime?
  purchase               InstallmentPurchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@unique([purchaseId, installmentNumber])
  @@index([chargeMonth, dueDate])
}

model SavingsGoal {
  id                         String       @id @default(cuid())
  userId                     String
  linkedAccountId            String?
  name                       String
  targetAmount               Decimal      @db.Decimal(12, 2)
  currentAmount              Decimal      @default(0) @db.Decimal(12, 2)
  targetDate                 DateTime?
  priority                   Priority     @default(MEDIUM)
  monthlySuggestedContribution Decimal    @default(0) @db.Decimal(12, 2)
  color                      String?
  icon                       String?
  isPinned                   Boolean      @default(false)
  notes                      String?
  createdAt                  DateTime     @default(now())
  updatedAt                  DateTime     @updatedAt
  user                       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  linkedAccount              Account?     @relation(fields: [linkedAccountId], references: [id], onDelete: SetNull)
  transactions               Transaction[]
  plannedPurchases           PlannedPurchase[]

  @@index([userId, priority])
}

model Budget {
  id                String       @id @default(cuid())
  userId            String
  name              String?
  scope             BudgetScope
  month             DateTime
  limitAmount       Decimal      @db.Decimal(12, 2)
  alertPercent      Int          @default(80)
  carryOver         Boolean      @default(false)
  categoryId        String?
  subcategoryId     String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  category          Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  subcategory       Subcategory? @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)

  @@index([userId, month, scope])
}

model FinancialRule {
  id              String          @id @default(cuid())
  userId          String
  name            String
  description     String?
  type            RuleType
  severity        InsightSeverity @default(INFO)
  config          Json
  isEnabled       Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  insights        SpendingInsight[]

  @@index([userId, isEnabled])
}

model SpendingInsight {
  id                    String              @id @default(cuid())
  userId                String
  ruleId                String?
  categoryId            String?
  installmentPurchaseId String?
  plannedPurchaseId     String?
  title                 String
  message               String
  severity              InsightSeverity
  status                InsightStatus       @default(ACTIVE)
  context               Json?
  createdAt             DateTime            @default(now())
  expiresAt             DateTime?
  user                  User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  rule                  FinancialRule?      @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  category              Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  installmentPurchase   InstallmentPurchase? @relation(fields: [installmentPurchaseId], references: [id], onDelete: SetNull)
  plannedPurchase       PlannedPurchase?    @relation(fields: [plannedPurchaseId], references: [id], onDelete: SetNull)

  @@index([userId, status, severity])
}

model PlannedPurchase {
  id                        String                @id @default(cuid())
  userId                    String
  linkedGoalId              String?
  seasonalityId             String?
  title                     String
  categoryKey               String
  priority                  Priority              @default(MEDIUM)
  status                    PlannedPurchaseStatus @default(IDEA)
  recommendation            RecommendationType    @default(WAIT)
  targetPrice               Decimal?              @db.Decimal(12, 2)
  expectedMinPrice          Decimal?              @db.Decimal(12, 2)
  expectedMaxPrice          Decimal?              @db.Decimal(12, 2)
  currentlySaved            Decimal               @default(0) @db.Decimal(12, 2)
  desiredDate               DateTime?
  suggestedMonthlySaving    Decimal?              @db.Decimal(12, 2)
  bestMonthNote             String?
  strategyNote              String?
  preferredStores           String[]
  referenceSites            String[]
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt
  user                      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  linkedGoal                SavingsGoal?          @relation(fields: [linkedGoalId], references: [id], onDelete: SetNull)
  seasonality               PurchaseSeasonality?  @relation(fields: [seasonalityId], references: [id], onDelete: SetNull)
  insights                  SpendingInsight[]

  @@index([userId, status, priority])
}

model PurchaseSeasonality {
  id                String              @id @default(cuid())
  userId            String?
  title             String
  categoryKey       String
  bestMonths        Int[]
  secondaryMonths   Int[]
  typicalRetailers  String[]
  recommendedSites  String[]
  priceRangeMin     Decimal?            @db.Decimal(12, 2)
  priceRangeMax     Decimal?            @db.Decimal(12, 2)
  guidance          String
  confidence        Int                 @default(70)
  strength          SeasonalityStrength @default(MEDIUM)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  user              User?               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plannedPurchases  PlannedPurchase[]

  @@index([userId, categoryKey])
}

model Notification {
  id            String             @id @default(cuid())
  userId        String
  title         String
  body          String
  type          NotificationType
  status        NotificationStatus @default(UNREAD)
  scheduledFor  DateTime?
  readAt        DateTime?
  actionUrl     String?
  metadata      Json?
  createdAt     DateTime           @default(now())
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, scheduledFor])
}
